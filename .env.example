# Groq API Key (get free key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Flask Server Port (optional, defaults to 5000)
PORT=5000

# ── YouTube Cookies (STRONGLY RECOMMENDED for cloud deployment) ──────────────
# Without this, the Render server IP may be blocked by YouTube bot detection.
# 
# HOW TO EXPORT YOUR COOKIES:
#   1. Install browser extension "Get cookies.txt LOCALLY" (Chrome/Firefox)
#   2. Go to https://www.youtube.com and make sure you are logged in
#   3. Click the extension icon → "Export" → "Current Site" → save as cookies.txt
#   4. Open cookies.txt, copy ALL the content
#   5. On Render dashboard → your service → Environment → add variable:
#        Key:   YOUTUBE_COOKIES
#        Value: (paste the entire cookies.txt content)
#
# For local development, you can also place cookies.txt in the project root.
YOUTUBE_COOKIES=
